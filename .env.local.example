# OpenAI API Key (fallback)
OPENAI_API_KEY=sk_your_key_here
BASE_URL=

# Anthropic API Key (fallback)
ANTHROPIC_API_KEY=sk_your_key_here
BASE_URL=

# ============ LI.FI Configuration ============
# Composer API Key (from https://portal.li.fi/)
NEXT_PUBLIC_LIFI_COMPOSER_API_KEY=

# LI.FI Earn Data API Base URL
NEXT_PUBLIC_LIFI_EARN_DATA_URL=https://earn.li.fi

# ============ Wallet Configuration ============
# WalletConnect Project ID (from https://cloud.walletconnect.com/)
NEXT_PUBLIC_WC_PROJECT_ID=

# ============ Optional: Per-Agent Model Override ============
MAIN_AGENT_MODEL=qwen-plus
EARNING_AGENT_MODEL=qwen-plus
BRIDGE_AGENT_MODEL=qwen-plus
RISK_AGENT_MODEL=qwen-plus
MONITOR_AGENT_MODEL=qwen-plus
