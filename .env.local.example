# ============ AI Models ============
# DeepSeek API Key
DEEPSEEK_API_KEY=
BASE_URL=

# Zhipu (智谱) API Key
ZHIPU_API_KEY=
BASE_URL=

# aliyun（阿里云）API Key
QWEN_API_KEY=
